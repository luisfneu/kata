{
  "title": "JVM Resources — Deep Dive",
  "uid": "jvm-resources",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Thread Count — JobManager",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_Threads_Count",
          "legendFormat": "Threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Thread Count — TaskManager",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_Threads_Count",
          "legendFormat": "Threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU Load — JobManager",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_CPU_Load",
          "legendFormat": "CPU",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Metaspace Used — TaskManager",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Metaspace_Used",
          "legendFormat": "Metaspace",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Non-Heap Memory — JobManager",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_NonHeap_Used",
          "legendFormat": "Non-Heap Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_NonHeap_Max",
          "legendFormat": "Non-Heap Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Metaspace_Used",
          "legendFormat": "Metaspace Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Metaspace_Max",
          "legendFormat": "Metaspace Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Non-Heap Memory — TaskManager",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_NonHeap_Used",
          "legendFormat": "Non-Heap Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_NonHeap_Max",
          "legendFormat": "Non-Heap Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Metaspace_Used",
          "legendFormat": "Metaspace Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Metaspace_Max",
          "legendFormat": "Metaspace Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC Time — JobManager (ms/min)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flink_jobmanager_Status_JVM_GarbageCollector_G1_Young_Generation_Time[1m])",
          "legendFormat": "G1 Young Time (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "rate(flink_jobmanager_Status_JVM_GarbageCollector_G1_Old_Generation_Time[1m])",
          "legendFormat": "G1 Old Time (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GC Time — TaskManager (ms/min)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Young_Generation_Time[1m])",
          "legendFormat": "G1 Young Time (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Old_Generation_Time[1m])",
          "legendFormat": "G1 Old Time (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Thread Count Over Time",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_Threads_Count",
          "legendFormat": "JobManager Threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_Threads_Count",
          "legendFormat": "TaskManager Threads",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Load Over Time — JobManager vs TaskManager",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_CPU_Load",
          "legendFormat": "JobManager CPU",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_CPU_Load",
          "legendFormat": "TaskManager CPU",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 10 } } }
    }
  ]
}
