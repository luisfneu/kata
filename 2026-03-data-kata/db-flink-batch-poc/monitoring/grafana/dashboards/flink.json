{
  "title": "Flink Overview",
  "uid": "flink-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Registered Task Managers",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_numRegisteredTaskManagers",
          "legendFormat": "TMs",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running Jobs",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_numRunningJobs",
          "legendFormat": "Jobs",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Available Task Slots",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_taskSlotsAvailable",
          "legendFormat": "Free Slots",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Task Slots",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "flink_jobmanager_taskSlotsTotal",
          "legendFormat": "Total Slots",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Heap Used — JobManager",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Used",
          "legendFormat": "Heap Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Max",
          "legendFormat": "Heap Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM Heap Used — TaskManager",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used",
          "legendFormat": "Heap Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Max",
          "legendFormat": "Heap Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Load — TaskManager",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_JVM_CPU_Load",
          "legendFormat": "CPU Load",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GC Collections — TaskManager",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Young_Generation_Count[1m])",
          "legendFormat": "G1 Young (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Old_Generation_Count[1m])",
          "legendFormat": "G1 Old (rate)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "fillOpacity": 10 } }
      }
    }
  ]
}
