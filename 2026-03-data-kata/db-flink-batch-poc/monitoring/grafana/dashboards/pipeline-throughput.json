{
  "title": "Pipeline Throughput",
  "uid": "pipeline-throughput",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Records In (all tasks)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(flink_taskmanager_job_task_numRecordsIn)",
          "legendFormat": "Records In",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Records Out (all tasks)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(flink_taskmanager_job_task_numRecordsOut)",
          "legendFormat": "Records Out",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Available Network Memory Segments",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_Network_AvailableMemorySegments",
          "legendFormat": "Available",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Flink Managed Memory Used",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_Flink_Memory_Managed_Used",
          "legendFormat": "Managed Memory",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Records In Rate — per task (records/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flink_taskmanager_job_task_numRecordsIn[30s]))",
          "legendFormat": "Records In/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(flink_taskmanager_job_task_operator_numRecordsIn[30s]))",
          "legendFormat": "Operator Records In/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Records Out Rate — per task (records/s)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flink_taskmanager_job_task_numRecordsOut[30s]))",
          "legendFormat": "Records Out/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(flink_taskmanager_job_task_operator_numRecordsOut[30s]))",
          "legendFormat": "Operator Records Out/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network Memory Segments — TaskManager",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_Network_TotalMemorySegments",
          "legendFormat": "Total Segments",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_Network_AvailableMemorySegments",
          "legendFormat": "Available Segments",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_Network_TotalMemorySegments - flink_taskmanager_Status_Network_AvailableMemorySegments",
          "legendFormat": "In-Use Segments",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Flink Managed Memory — TaskManager",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_Flink_Memory_Managed_Total",
          "legendFormat": "Managed Total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_Flink_Memory_Managed_Used",
          "legendFormat": "Managed Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Shuffle / Netty Memory — TaskManager",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flink_taskmanager_Status_Shuffle_Netty_TotalMemory",
          "legendFormat": "Netty Total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "flink_taskmanager_Status_Shuffle_Netty_UsedMemory",
          "legendFormat": "Netty Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Bytes In/Out Rate — TaskManager",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(flink_taskmanager_job_task_numBytesIn[30s]))",
          "legendFormat": "Bytes In/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(rate(flink_taskmanager_job_task_numBytesOut[30s]))",
          "legendFormat": "Bytes Out/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10 } } }
    }
  ]
}
